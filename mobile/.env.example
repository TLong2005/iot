# Optional. Leave empty for Expo Go to auto-use dev machine IP (same WiFi).
# Override example: EXPO_PUBLIC_SOCKET_URL=http://192.168.1.10:3000
# Android emulator: http://10.0.2.2:3000
EXPO_PUBLIC_SOCKET_URL=

# Demo học: bỏ màn nhập mã — vào thẳng màn giám sát (khớp SAFETY_PAIRING_ENABLED=false trên API).
EXPO_PUBLIC_SKIP_DEVICE_PAIRING=true
EXPO_PUBLIC_DEMO_DEVICE_ID=esp32-sim-01
EXPO_PUBLIC_DEMO_PAIRING_SECRET=home-secret

# Nếu SKIP=false: bật ghép socket (cần backend SAFETY_PAIRING_ENABLED=true).
# EXPO_PUBLIC_PAIRING_REQUIRED=false

# Số cứu hỏa (VN mặc định 114). Nút "Gọi cứu hỏa" mở tel:...
# EXPO_PUBLIC_FIRE_NUMBER=114

NODE_ENV=development
HTTP_PORT=3000

# MQTT (TLS)
MQTT_URL=mqtts://localhost:8883
MQTT_TOPIC=sensors/safety
MQTT_USERNAME=
MQTT_PASSWORD=
# Paths to PEM files (optional; if unset, broker CA may still be verified via MQTT_CA_FILE)
# Relative to backend/ when running `npm run start` from backend/
MQTT_CA_FILE=../infra/mosquitto/certs/ca.crt
MQTT_CERT_FILE=
MQTT_KEY_FILE=
MQTT_REJECT_UNAUTHORIZED=true

# Redis (rolling buffer + BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=iot
DB_PASSWORD=iot_secret_change_me
DB_NAME=iot_mvp
DB_SYNC=true

# Emergency thresholds (document spec)
THRESHOLD_GAS=300
THRESHOLD_TEMP=50

# Min ms between DB/socket emergency dispatches per device (live φ still updates)
ALERT_COOLDOWN_MS=45000

# --- Ghép đôi app ↔ thiết bị (giống camera nhà) ---
SAFETY_PAIRING_ENABLED=true
# Sinh chuỗi ngẫu nhiên; dùng header x-setup-token khi POST /devices/register
SETUP_TOKEN=change-me-setup-token
# Trộn hash mã ghép nối (đổi khi deploy thật)
DEVICE_SECRET_PEPPER=change-me-pepper
# Đăng ký sẵn khi backend khởi động: deviceId:pairingSecret (khớp app + simulator)
BOOTSTRAP_DEVICES=esp32-sim-01:home-secret
